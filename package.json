{
  "name": "playwright-2026",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed --project=chromium",
    "auth:refresh": "node -e \"const fs=require('fs');const p='playwright/.auth/user.json';if(fs.existsSync(p)){fs.unlinkSync(p);console.log('Removed',p)}else{console.log('No state file to remove')}\"",
    "auth:init": "playwright test tests/setup/auth.setup.js --project=setup",
    "report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/cli": "^0.1.6",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.3.3",
    "dotenv": "^10.0.0"
  }
}
